{
  "name": "@sous/cli",
  "version": "0.1.0",
  "description": "Sous LLM Config Manager CLI",
  "type": "module",
  "bin": {
    "xcv": "./bin/xcv",
    "sous": "./bin/xcv"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@oclif/color": "^1.0.13",
    "@oclif/core": "^4",
    "@sous/core": "workspace:*",
    "chokidar": "^5.0.0",
    "glob": "^13.0.6",
    "liquidjs": "^10.25.0",
    "minimatch": "^10.2.5",
    "tiktoken": "^1.0.22",
    "tsx": "^4"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/node": "^22",
    "memfs": "^4.56.11"
  },
  "oclif": {
    "bin": "xcv",
    "dirname": "xcv",
    "flexibleTaxonomy": true,
    "topicSeparator": " ",
    "commands": {
      "strategy": "pattern",
      "target": "./src/commands"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
