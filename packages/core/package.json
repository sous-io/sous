{
  "name": "@sous/core",
  "version": "0.1.0",
  "description": "Sous core library (shared across CLI, MCP, and hub packages)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
