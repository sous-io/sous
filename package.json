{
  "name": "sous",
  "version": "0.1.0",
  "description": "Sous LLM Config Manager (monorepo root)",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm --filter @sous/cli test:e2e",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.18.0",
    "typescript": "^5",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0"
}
